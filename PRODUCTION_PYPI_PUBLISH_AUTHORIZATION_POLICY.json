{
  "schema": "verifrax.python.production-pypi-publish-authorization-policy.v1",
  "status": "ACTIVE_DEADMAN_BOUNDARY",
  "package": "verifrax",
  "version": "0.1.0",
  "source_repo": "Verifrax/VERIFRAX-PY",
  "do_not_publish": true,
