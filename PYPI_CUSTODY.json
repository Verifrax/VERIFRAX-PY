{
  "schema": "verifrax.python.pypi-custody.v1",
  "status": "ACTIVE_BOUNDARY",
  "pypi_project": "verifrax",
  "source_repo": "Verifrax/VERIFRAX-PY",
  "publisher": {
    "method": "pypi-trusted-publishing",
    "oidc_provider": "github-actions",
    "workflow": ".github/workflows/pypi-publish.yml",
    "environment": "pypi"
  },
  "release_requirements": {
    "trusted_publishing_required": true,
    "attestation_required": true,
    "sdist_required": true,
    "wheel_required": true,
    "testpypi_rehearsal_required": true,
    "refusal_tests_required": true,
    "source_binding_check_required": true,
    "cli_smoke_required": true,
    "release_candidate_readiness_required": true,
    "pytest_warning_free_required": true,
    "terminal_nonrecognition_nonrecourse_guard_required": true,
    "receipt_verdict_projection_replay_required": true,
    "api_machine_contract_replay_required": true,
    "testpypi_pending_trusted_publisher_required": true,
    "pypi_pending_trusted_publisher_required": true,
    "do_not_publish_without_testpypi_live_rehearsal_proof": true
  },
  "forbidden": [
    "manual_password_publish",
    "long_lived_token_publish",
    "unattested_release",
    "source_repo_mismatch",
    "empty_namespace_reservation",
    "sovereign_chamber_distribution"
  ],
  "trusted_publisher_readiness": {
    "status": "DECLARED_NOT_PUBLISHED",
    "do_not_publish": true,
    "testpypi": {
      "owner": "Verifrax",
      "repository": "VERIFRAX-PY",
      "workflow": "testpypi-publish.yml",
      "environment": "testpypi",
      "pending_trusted_publisher_required": true
    },
    "pypi": {
      "owner": "Verifrax",
      "repository": "VERIFRAX-PY",
      "workflow": "pypi-publish.yml",
      "environment": "pypi",
      "pending_trusted_publisher_required": true
    }
  }
}
