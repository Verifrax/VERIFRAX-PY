{
  "schema": "verifrax.python.pypi-custody.v1",
  "status": "ACTIVE_BOUNDARY",
  "pypi_project": "verifrax",
  "source_repo": "Verifrax/VERIFRAX-PY",
  "publisher": {
    "method": "pypi-trusted-publishing",
    "oidc_provider": "github-actions",
    "workflow": ".github/workflows/pypi-publish.yml",
    "environment": "pypi"
  },
  "release_requirements": {
    "trusted_publishing_required": true,
    "attestation_required": true,
    "sdist_required": true,
    "wheel_required": true,
    "testpypi_rehearsal_required": true,
    "refusal_tests_required": true,
    "source_binding_check_required": true,
    "cli_smoke_required": true
  },
  "forbidden": [
    "manual_password_publish",
    "long_lived_token_publish",
    "unattested_release",
    "source_repo_mismatch",
    "empty_namespace_reservation",
    "sovereign_chamber_distribution"
  ]
}
