{
  "schema": "verifrax.python.pypi-custody.v1",
  "status": "ACTIVE_BOUNDARY",
  "pypi_project": "verifrax",
  "source_repo": "Verifrax/VERIFRAX-PY",
  "publisher": {
    "method": "pypi-trusted-publishing",
    "oidc_provider": "github-actions",
    "workflow": ".github/workflows/pypi-publish.yml",
    "environment": "pypi"
  },
  "release_requirements": {
    "trusted_publishing_required": true,
    "attestation_required": true,
    "sdist_required": true,
    "wheel_required": true,
    "testpypi_rehearsal_required": true,
    "refusal_tests_required": true,
    "source_binding_check_required": true,
    "cli_smoke_required": true,
    "release_candidate_readiness_required": true,
    "pytest_warning_free_required": true,
    "terminal_nonrecognition_nonrecourse_guard_required": true,
    "receipt_verdict_projection_replay_required": true,
    "api_machine_contract_replay_required": true,
    "testpypi_pending_trusted_publisher_required": true,
    "pypi_pending_trusted_publisher_required": true,
    "do_not_publish_without_testpypi_live_rehearsal_proof": true,
    "production_pypi_publish_deadman_required": true,
    "production_pypi_publish_authorization_required": true,
    "testpypi_live_rehearsal_proof_required": true,
    "production_publish_default_refuse": true,
    "external_trusted_publisher_claim_lock_required": true,
    "release_artifact_digest_replay_required": true
  },
  "forbidden": [
    "manual_password_publish",
    "long_lived_token_publish",
    "unattested_release",
    "source_repo_mismatch",
    "empty_namespace_reservation",
    "sovereign_chamber_distribution"
  ],
  "trusted_publisher_readiness": {
    "status": "DECLARED_NOT_PUBLISHED",
    "do_not_publish": true,
    "testpypi": {
      "owner": "Verifrax",
      "repository": "VERIFRAX-PY",
      "workflow": "testpypi-publish.yml",
      "environment": "testpypi",
      "pending_trusted_publisher_required": true
    },
    "pypi": {
      "owner": "Verifrax",
      "repository": "VERIFRAX-PY",
      "workflow": "pypi-publish.yml",
      "environment": "pypi",
      "pending_trusted_publisher_required": true
    },
    "production_publish_default": "REFUSE",
    "production_publish_deadman": {
      "authorization_check": "scripts/check-production-pypi-publish-authorization-boundary.py",
      "deadman_check": "scripts/check-production-pypi-publish-deadman-boundary.py",
      "policy": "PRODUCTION_PYPI_PUBLISH_AUTHORIZATION_POLICY.json",
      "required_authorization": "PYPI_PRODUCTION_PUBLISH_AUTHORIZATION.json",
      "required_testpypi_live_rehearsal_proof": "evidence/testpypi-live-rehearsal/TESTPYPI_LIVE_REHEARSAL_PROOF.json"
    },
    "external_claim_lock": {
      "path": "EXTERNAL_TRUSTED_PUBLISHER_CLAIMS.json",
      "gate": "scripts/check-external-trusted-publisher-claim-lock-boundary.py"
    }
  },
  "release_artifact_digest_replay_boundary": {
    "status": "REQUIRED",
    "gate": "scripts/check-release-artifact-digest-replay-boundary.py",
    "policy": "RELEASE_ARTIFACT_DIGEST_BOUNDARY.json",
    "do_not_publish": true
  }
}
